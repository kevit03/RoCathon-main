# Recommended for the best semantic accuracy
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# "openai" for production-quality embeddings, "local" for offline deterministic embeddings
EMBEDDING_PROVIDER=openai

# "postgres" for the hackathon submission path, "memory" for a self-contained local fallback,
# or "auto" to use Postgres when DATABASE_URL is set and memory otherwise.
VECTOR_BACKEND=postgres

# Supabase connection string (or local Docker postgres with pgvector)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
